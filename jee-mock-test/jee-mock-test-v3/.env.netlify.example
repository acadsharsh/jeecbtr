# ════════════════════════════════════════════════════════════════════
# Netlify Environment Variables — Supabase Auth Edition
# Set in: Netlify Dashboard → Site Configuration → Environment Variables
# ════════════════════════════════════════════════════════════════════

# ─── Supabase ────────────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# Mark as Secret in Netlify dashboard:
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ─── App ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-site-name.netlify.app
